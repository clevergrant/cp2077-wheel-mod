settings_local.lua

# Development and testing
test/
debug/
temp/

# Documentation build artifacts
docs/_build/
docs/.doctrees/

# IDE files
*.swp
*.swo
*~

# Runtime logs and crash dumps
crash_*.dmp
error_*.log
